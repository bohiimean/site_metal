# Шаблон .env. Скопировать в .env и заполнить. Сам .env — в .gitignore.
# Какой режим используется, определяет DJANGO_SETTINGS_MODULE
# (задаётся в docker-compose: local в dev, production в проде).

# ── Django ────────────────────────────────────────────────────────────
# Сгенерировать: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=
# Прод: домены через запятую, без схемы
ALLOWED_HOSTS=example.ru,www.example.ru
# Полный URL сайта со схемой — для ссылок в Telegram-уведомлениях
# и CSRF_TRUSTED_ORIGINS
SITE_URL=https://example.ru

# ── Nginx / сертификат (только прод) ──────────────────────────────────
DOMAIN=example.ru
# Необязательный второй домен: 301-редирект на DOMAIN. Кириллицу писать
# в punycode (арвенокс.рф → xn--80aejuogkn.xn--p1ai). Пусто = выключено.
# Сертификат общий с DOMAIN (оба домена в SAN одного серта, см. DEPLOY.md),
# поэтому отдельный серт под этот домен не нужен и пустое значение безопасно.
# ВАЖНО: у второго домена не должно быть AAAA-записи (IPv6), если сервер не
# обслуживает IPv6 — иначе HTTP-01-валидация LE уходит по IPv6 не на сервер.
REDIRECT_DOMAIN=

# ── PostgreSQL ────────────────────────────────────────────────────────
DB_NAME=metal
DB_USER=metal
DB_PASSWORD=
DB_HOST=db
DB_PORT=5432

# ── Redis (только прод; кэш и rate-limit форм) ────────────────────────
REDIS_URL=redis://redis:6379/1

# ── Gunicorn (только прод) ────────────────────────────────────────────
# По умолчанию: CPU × 2 + 1
GUNICORN_WORKERS=3

# ── Telegram-уведомления о заявках ────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Яндекс SmartCaptcha ───────────────────────────────────────────────
YANDEX_CAPTCHA_SERVER_KEY=
YANDEX_CAPTCHA_CLIENT_KEY=
